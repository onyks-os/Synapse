# Synapse — example environment (copy to `.env` for docker-compose or export locally).
# Do not commit real secrets. Values shown are illustrative defaults.

# -----------------------------------------------------------------------------
# Node Configuration
# -----------------------------------------------------------------------------
DEATH_TIMEOUT=6.0
EVICTION_TTL=10.0
SYNAPSE_ZMQ_PORT=5555
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Identity (optional; otherwise HOSTNAME / UUID)
# NODE_ID=node-1

# Fixed position (optional; otherwise random within LAT/LON box or defaults)
# SENSOR_LAT=45.464
# SENSOR_LON=9.190
LAT_MIN=44.0
LAT_MAX=47.5
LON_MIN=6.5
LON_MAX=14.0

# Mock reading override (optional)
# SENSOR_VALUE=22.5
PING_INTERVAL=2.0
H3_RESOLUTION=7

# -----------------------------------------------------------------------------
# Peer Discovery Configuration
# -----------------------------------------------------------------------------
# Discovery method: beacon | static
SYNAPSE_DISCOVERY=beacon

# If static, provide comma-separated list of peers:
# SYNAPSE_PEERS=node-2:5555,node-3:5555

# Beacon settings (if discovery=beacon)
SYNAPSE_BEACON_INTERVAL=2.0
SYNAPSE_BEACON_TIMEOUT=6.0
SYNAPSE_BEACON_GROUP=239.255.77.77
SYNAPSE_BEACON_PORT=5670

# -----------------------------------------------------------------------------
# Spatial corroboration: mad | zscore | both
# -----------------------------------------------------------------------------
CORROBORATION_METHOD=mad
ANOMALY_ZSCORE_THRESHOLD=2.0
CORROBORATION_MIN_PEERS=2

# Ingest rate limiting
RATE_LIMIT_MSG_PER_SEC=100
RATE_LIMIT_BURST=20

# HTTP API + dashboard: set to require Bearer / X-API-Key on /api/* and /metrics
# SYNAPSE_DASHBOARD_API_KEY=

# Structured logs: json | text (see src/core/event_logger.py)
SYNAPSE_LOG_FORMAT=json

# Optional SQLite persistence for node rows (empty = in-memory only)
# SYNAPSE_REGISTRY_DB=/data/registry.db

# -----------------------------------------------------------------------------
# Optional ZeroMQ CURVE (mutual auth): keys + shared peer keys file
# -----------------------------------------------------------------------------
# SYNAPSE_CURVE_PUBLICKEY=
# SYNAPSE_CURVE_SECRETKEY=
# SYNAPSE_CURVE_PEER_KEYS_FILE=/config/peer_keys.txt
# SYNAPSE_CURVE_ZAP_DOMAIN=*
